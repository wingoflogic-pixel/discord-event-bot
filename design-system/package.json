{
  "name": "@eventbot/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EventBot 管理UI のデザインシステム（React コンポーネント層）。共有CSSコア(styles/)の class を出力する。",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles/index.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "sync:ui": "node sync-ui.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.24.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3"
  }
}
