# 環境変数サンプル（CLI でのスラッシュコマンド登録用）
#
# この .env は scripts/register-commands.js（CLI でのコマンド登録）専用です。
# 通常は管理画面の「コマンドを登録」ボタンで登録でき、.env は不要です。
#
# Worker 実行時のシークレット（DISCORD_PUBLIC_KEY / DISCORD_BOT_TOKEN / ADMIN_TOKEN 等）は
# 本番は `wrangler secret`、ローカル検証は `.dev.vars` で設定します（.env ではありません）。

# Discord Bot Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application ID
DISCORD_APPLICATION_ID=your_application_id_here

# 登録先ギルド（任意）。指定するとそのサーバーへ即時登録（テスト向け）。
# 未指定はグローバル登録（反映に最大1時間）。
DISCORD_GUILD_ID=your_guild_id_here
