{
  "name": "discord-event-bot",
  "version": "7.0.0",
  "description": "汎用 Discord イベント出欠 Bot（Cloudflare Workers + D1・管理UI付き）。マルチサーバー対応・Server ＞ Notification → Segment ＞ Occurrence モデル。",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply choiemu-event-bot-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply choiemu-event-bot-db --remote",
    "register-commands": "node scripts/register-commands.js",
    "migrate-from-sheets": "node scripts/migrate-from-sheets.mjs"
  },
  "dependencies": {
    "discord-interactions": "^4.1.0",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.16",
    "@cloudflare/workers-types": "^4.20260617.1",
    "dotenv": "^17.3.1",
    "googleapis": "^144.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
